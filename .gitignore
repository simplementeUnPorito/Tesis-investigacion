# ---- Obsidian Vault Gitignore ----
# Ignorar archivos de workspace que cambian constantemente
.obsidian/workspace.json
.obsidian/workspaces.json

# Ignorar cache interno de Obsidian
.obsidian/cache/
.obsidian/plugins/community-plugins/cache/

# Ignorar snapshots temporales de edición
*.tmp
*.swp
*.swo

# Ignorar backups locales de plugins que no necesitas versionar
.obsidian/plugins/*/backups/

# Ignorar logs internos si existen
.obsidian/logs/
